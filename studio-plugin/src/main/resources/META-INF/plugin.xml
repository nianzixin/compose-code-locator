<idea-plugin>
    <id>io.github.nianzixin.compose-code-locator</id>
    <name>Compose Code Locator</name>
    <version>0.1.3</version>
    <vendor url="https://github.com/nianzixin/compose-code-locator">nianzixin</vendor>
    <idea-version since-build="241" until-build="253.*" />

    <description><![CDATA[
        Compose Code Locator provides Android Studio screenshot-to-source navigation for Jetpack Compose debug builds.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="Compose Code Locator"
            factoryClass="dev.codelocator.studio.intellij.ComposeLocatorToolWindowFactory"
            anchor="right" />
    </extensions>

    <actions>
        <action
            id="dev.codelocator.studio.CaptureAndLocate"
            class="dev.codelocator.studio.intellij.CaptureAndLocateAnAction"
            text="Compose Code Locator"
            description="Open the Compose Code Locator tool window" />
    </actions>
</idea-plugin>
